[System]
Name='Smart Workout Suggestion System'
Type='mamdani'
Version=2.0
NumInputs=7
NumOutputs=3
NumRules=343
AndMethod='min'
OrMethod='max'
ImpMethod='min'
AggMethod='max'
DefuzzMethod='centroid'

[Input1]
Name='Age'
Range=[15 70]
NumMFs=3
MF1='Young':'trimf',[15 25 35]
MF2='Adult':'trimf',[30 45 60]
MF3='Old':'trimf',[55 65 70]

[Input2]
Name='BMI'
Range=[15 40]
NumMFs=4
MF1='Underweight':'trimf',[15 16.5 18.5]
MF2='Normal':'trimf',[18.5 21.5 25]
MF3='Overweight':'trimf',[25 27.5 30]
MF4='Obese':'trimf',[30 32.5 40]

[Input3]
Name='Daily_Activity_Level'
Range=[1 4]
NumMFs=4
MF1='Sedentary':'trimf',[1 1.5 2]
MF2='Lightly_Active':'trimf',[1.5 2 2.5]
MF3='Moderately_Active':'trimf',[2 2.5 3]
MF4='Very_Active':'trimf',[2.5 3 4]

[Input4]
Name='Resting_Heart_Rate'
Range=[40 100]
NumMFs=3
MF1='Low':'trimf',[40 50 60]
MF2='Normal':'trimf',[60 70 80]
MF3='High':'trimf',[80 90 100]

[Input5]
Name='Strength_Level'
Range=[1 10]
NumMFs=3
MF1='Weak':'trimf',[1 2 3]
MF2='Average':'trimf',[3 5 7]
MF3='Strong':'trimf',[7 8.5 10]

[Input6]
Name='Flexibility'
Range=[1 10]
NumMFs=3
MF1='Poor':'trimf',[1 2 3]
MF2='Average':'trimf',[3 5 7]
MF3='Good':'trimf',[7 8.5 10]

[Input7]
Name='Sleep_Quality'
Range=[0 9]
NumMFs=3
MF1='Poor':'trimf',[0 2.5 5]
MF2='Average':'trimf',[5 6 7]
MF3='Good':'trimf',[7 8 9]

[Output1]
Name='Overall_Fitness'
Range=[3 9]
NumMFs=3
MF1='Poor':'trimf',[3 4 5]
MF2='Average':'trimf',[5 6 7]
MF3='Excellent':'trimf',[7 8 9]

[Output2]
Name='Workout_Intensity'
Range=[3 9]
NumMFs=3
MF1='Low':'trimf',[3 4 5]
